# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Resend
RESEND_API_KEY=re_...

# Cron security (make up a long random string)
CRON_SECRET=some-long-random-string-here

# Admin access (simple password for MVP)
ADMIN_PASSWORD=choose-a-password

# Google OAuth (Gmail connector)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://coelacanth-zeta.vercel.app/api/auth/gmail/callback

# Slack OAuth (Slack connector)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://coelacanth-zeta.vercel.app/api/auth/slack/callback
